# Goneat ignore patterns for TSFulmen (honored by `goneat format` AND `goneat assess`).
# Excludes files that should not be formatted/linted.

# SSOT assets synced from Crucible (make sync-ssot) — owned upstream. Reformatting
# them locally drifts from the SSOT source and changes what `make embed-assets`
# generates; fixes belong in Crucible, not here.
config/crucible-ts/
schemas/crucible-ts/
docs/crucible-ts/

# Generated embedded-asset modules (regenerated by make embed-assets).
src/assets/generated/

# Test fixtures, including deliberately invalid/malformed inputs — formatting them
# would "fix" the very inputs the tests rely on, or break exact-bytes comparisons.
**/fixtures/
**/__fixtures__/

# Build output.
dist/
coverage/
